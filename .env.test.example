# Copy this to .env.test and fill in your test Convex deployment URL.
#
# The URL must contain "test" (e.g. https://something-test.convex.cloud) — the
# Playwright globalSetup refuses to run otherwise, as a safety measure against
# accidentally pointing the test suite at dev or prod.
#
# To provision a dedicated test deployment:
#   1. Run `npx convex dev --once --configure=new` and name it `fulbin-test`.
#   2. Copy the printed deployment URL into TEST_CONVEX_URL below.
#   3. Deploy the test-only mutations: `npx convex deploy` against fulbin-test.

TEST_CONVEX_URL=https://your-fulbin-test.convex.cloud
