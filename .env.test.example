# Copy this to .env.test (gitignored) and fill in the values below.
#
# TEST_CONVEX_URL — the Convex deployment the E2E suite hits. Playwright forces
#   the Vite dev server to use this URL regardless of your .env.local.
#
# ALLOW_TEST_MUTATIONS — required opt-in when the URL does NOT contain "test".
#   We run against the shared dev deployment (the Vercel-managed Convex team
#   can't create a dedicated test project via CLI), so this is set to 1. If you
#   ever provision a real *-test deployment, swap the URL and drop this line.
#
# E2E_SECRET — shared secret guarding the test-only Convex mutations in
#   convex/testing.ts. It must match the value configured on the deployment:
#     npx convex env set E2E_SECRET <value>
#   Generate one with: node -e "console.log(require('crypto').randomBytes(24).toString('hex'))"

TEST_CONVEX_URL=https://your-deployment.convex.cloud
ALLOW_TEST_MUTATIONS=1
E2E_SECRET=replace-with-the-value-set-on-the-deployment
